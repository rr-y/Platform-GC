# Local development defaults. Copy to .env (do not commit .env).
# For production, set these in the Railway dashboard — see the "Production"
# block at the bottom for the required keys.

APP_ENV=development
SECRET_KEY=change-me-run-openssl-rand-hex-32
LOG_LEVEL=DEBUG
# Comma-separated allowlist of origins; "*" is fine for local dev only.
CORS_ORIGINS=*

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/platform_gc
REDIS_URL=redis://localhost:6379/0

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Enables POST /auth/admin/bootstrap while set; leave empty in prod after
# bootstrapping your first admin.
ADMIN_SECRET_KEY=

COINS_EARN_RATE=5.0
COIN_RUPEE_VALUE=0.10
MAX_COINS_REDEEM_PERCENT=0.20
COINS_EXPIRY_DAYS=365
EXPIRY_NOTIFY_DAYS=7

TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+1234567890

# Static review credentials for Play Store / App Store submission. When both
# are set the OTP flow for this mobile skips Twilio + rate limits and accepts
# the fixed OTP. Leave blank to disable. Mobile must be E.164 (e.g. +919999999999).
TEST_MOBILE_NUMBER=
TEST_OTP=

# ── Print Store ───────────────────────────────────────────────────────────────
# Per-page rates (₹). Customer pays (pages_to_print * copies * rate) minus any
# redeemed coins.
PRINT_PRICE_BW_PER_PAGE=2.0
PRINT_PRICE_COLOR_PER_PAGE=10.0
PRINT_MAX_FILE_SIZE_MB=25
# Where uploaded files live. On Railway, mount a persistent Volume at /data and
# keep the default. Locally docker-compose bind-mounts ./data to /data.
PRINT_STORAGE_DIR=/data/prints
PRINT_DRAFT_TTL_HOURS=1
PRINT_UNCOLLECTED_RETENTION_DAYS=30
# Shared secret the Raspberry Pi sends as X-Device-Key. Blank disables the
# device endpoints — leave it blank anywhere a Pi is not actually connected.
DEVICE_API_KEY=

# ── Production (Railway) ──────────────────────────────────────────────────────
# Set these in the Railway dashboard (do not put them in this file):
#   APP_ENV=production
#   SECRET_KEY=<32-byte random: python -c "import secrets; print(secrets.token_urlsafe(32))">
#   LOG_LEVEL=INFO
#   CORS_ORIGINS=https://your-admin.example.com,https://your-app.example.com
#   DATABASE_URL=<Railway Postgres connection string>
#   REDIS_URL=<Railway Redis connection string>
#   TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM_NUMBER
#   ADMIN_SECRET_KEY=<leave unset once first admin exists>
#   TEST_MOBILE_NUMBER, TEST_OTP — set only while the Play Store / App Store
#     reviewer account is active; clear both once review is complete
#   PRINT_STORAGE_DIR=/data/prints (attach a ~5GB Railway Volume mounted at /data)
#   DEVICE_API_KEY=<long random string> — share with the shop Raspberry Pi
