              "mode": "raw",
              "raw": "{\n  \"codes\": [\"AUTO\"],\n  \"is_auto_apply\": true,\n  \"per_user_limit\": 999\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/campaigns/{{campaign_id}}/coupons",
