            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codes\": [\"COKE90\"],\n  \"is_auto_apply\": false,\n  \"max_uses\": 500,\n  \"per_user_limit\": 3\n}"
